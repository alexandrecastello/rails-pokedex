<!DOCTYPE html>
<html class="light" lang="pt-BR">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title><%= content_for?(:title) ? yield(:title) : "Field Journal — Pokédex" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "on-tertiary-fixed-variant": "#544600",
              "primary-fixed": "#ffdad5",
              "on-secondary-fixed": "#001d36",
              "outline-variant": "#eabcb6",
              "surface-variant": "#e4e2e1",
              "background": "#fbf9f8",
              "on-surface-variant": "#5f3f3a",
              "surface-tint": "#c0000a",
              "on-error": "#ffffff",
              "surface-container": "#f0eded",
              "surface-bright": "#fbf9f8",
              "secondary-fixed-dim": "#9ecaff",
              "on-primary-fixed-variant": "#930005",
              "surface": "#fbf9f8",
              "inverse-primary": "#ffb4aa",
              "on-primary-container": "#fffbff",
              "error-container": "#ffdad6",
              "primary": "#bc000a",
              "surface-container-highest": "#e4e2e1",
              "on-secondary-fixed-variant": "#00497d",
              "tertiary-fixed-dim": "#e8c41d",
              "on-primary-fixed": "#410001",
              "surface-container-low": "#f6f3f2",
              "tertiary-container": "#c9a900",
              "primary-container": "#ea000f",
              "inverse-surface": "#303030",
              "tertiary-fixed": "#ffe16e",
              "on-primary": "#ffffff",
              "on-background": "#1b1c1c",
              "on-tertiary-fixed": "#221b00",
              "secondary-container": "#33a0fd",
              "secondary-fixed": "#d1e4ff",
              "secondary": "#0061a4",
              "on-tertiary-container": "#4c3f00",
              "on-secondary": "#ffffff",
              "surface-container-high": "#eae8e7",
              "tertiary": "#705d00",
              "on-surface": "#1b1c1c",
              "on-error-container": "#93000a",
              "outline": "#946e69",
              "primary-fixed-dim": "#ffb4aa",
              "on-secondary-container": "#00355c",
              "surface-dim": "#dcd9d9",
              "surface-container-lowest": "#ffffff",
              "error": "#ba1a1a",
              "inverse-on-surface": "#f3f0f0",
              "on-tertiary": "#ffffff"
            },
            fontFamily: {
              "headline": ["Plus Jakarta Sans", "sans-serif"],
              "body": ["Plus Jakarta Sans", "sans-serif"],
              "label": ["Plus Jakarta Sans", "sans-serif"]
            },
            borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
          },
        },
      }
    </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .pokemon-card:hover .pokemon-image {
      transform: scale(1.1) translateY(-8px);
    }
  </style>
</head>
<body class="bg-background font-body text-on-background selection:bg-primary-fixed">
<%= yield %>
</body>
</html>
