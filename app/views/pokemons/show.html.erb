<% content_for :title, "Field Journal — ##{@pokemon.national_number.to_s.rjust(3, '0')} #{@pokemon.name}" %>
<header class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-lg flex items-center justify-between px-6 h-20 max-w-full mx-auto">
  <div class="flex items-center gap-4">
    <span class="font-bold text-on-surface uppercase tracking-tight">Field Journal</span>
  </div>
</header>

<main class="pt-24 pb-32 px-6 lg:px-12 max-w-7xl mx-auto lg:ml-64">
  <nav class="mb-8">
    <%= link_to pokemons_path, class: "inline-flex items-center gap-2 text-slate-500 hover:text-primary transition-colors font-medium" do %>
      <span class="material-symbols-outlined">arrow_back</span>
      <span>Voltar à lista</span>
    <% end %>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
    <div class="lg:col-span-5 space-y-8">
      <div class="relative group">
        <span class="absolute -top-12 -left-4 text-9xl font-black text-on-surface/5 pointer-events-none tracking-tighter">
          #<%= @pokemon.national_number.to_s.rjust(3, "0") %>
        </span>
        <div class="relative aspect-square rounded-[2.5rem] bg-surface-container-low overflow-visible flex items-center justify-center">
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/5 to-transparent rounded-[2.5rem]"></div>
          <% if @pokemon.sprite_url.present? %>
            <%= image_tag @pokemon.sprite_url, alt: @pokemon.name, class: "w-4/5 h-4/5 object-contain z-10 transition-transform duration-500 group-hover:scale-105" %>
          <% else %>
            <span class="material-symbols-outlined text-9xl text-slate-300 z-10">pets</span>
          <% end %>
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          <% pokemon_types_ordered(@pokemon).each do |t| %>
            <% st = type_styles(t.name) %>
            <span class="px-5 py-2 rounded-full text-white text-xs font-bold tracking-widest uppercase <%= st[:chip] %>"><%= t.name %></span>
          <% end %>
        </div>
      </div>

      <div class="p-8 rounded-3xl bg-surface-container-low">
        <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4">Classificação biológica</h2>
        <div class="grid grid-cols-2 gap-6">
          <div>
            <p class="text-sm text-slate-500">Altura</p>
            <p class="text-xl font-bold"><%= format_height_dm(@pokemon.height) %></p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Peso</p>
            <p class="text-xl font-bold"><%= format_weight_hg(@pokemon.weight) %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-7 space-y-12">
      <div>
        <h1 class="text-5xl lg:text-7xl font-black text-on-surface tracking-tighter leading-none mb-4 uppercase"><%= @pokemon.name %></h1>
        <p class="text-xl text-slate-500 max-w-xl leading-relaxed">
          <%= @pokemon.flavor_text.presence || "Sem descrição de campo disponível." %>
        </p>
      </div>

      <% stats = ordered_pokemon_stats(@pokemon) %>
      <% if stats.any? %>
        <% bst = stats.sum(&:base_value) %>
        <section>
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-bold">Estatísticas base</h3>
            <span class="text-primary font-bold bg-primary/10 px-3 py-1 rounded-lg text-sm">BST: <%= bst %></span>
          </div>
          <div class="space-y-5">
            <% stats.each do |stat| %>
              <div class="group">
                <div class="flex justify-between mb-2">
                  <span class="text-sm font-bold text-slate-600 uppercase tracking-wider"><%= stat_label(stat.name) %></span>
                  <span class="text-sm font-bold"><%= stat.base_value %></span>
                </div>
                <div class="h-3 w-full bg-surface-container-high rounded-full overflow-hidden">
                  <div class="h-full bg-primary transition-all duration-1000" style="width: <%= stat_bar_width_percent(stat.base_value) %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if @pokemon.flavor_text.present? %>
        <section class="bg-surface-container-lowest p-8 rounded-3xl relative overflow-hidden">
          <div class="absolute top-0 right-0 p-6 opacity-10">
            <span class="material-symbols-outlined text-6xl">science</span>
          </div>
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-primary mb-4 flex items-center gap-2">
            <span class="w-8 h-[2px] bg-primary"></span>
            Notas de pesquisa
          </h3>
          <div class="prose prose-slate max-w-none italic text-slate-600 leading-loose font-medium">
            <%= @pokemon.flavor_text %>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</main>

<aside class="hidden lg:flex fixed left-0 top-20 h-[calc(100vh-5rem)] w-64 flex-col py-8 px-6 gap-4 bg-surface-container-low z-40">
  <div class="mb-6">
    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest px-4">Field Records</h3>
  </div>
  <nav class="space-y-1">
    <%= link_to pokemons_path, class: "flex items-center gap-4 px-4 py-3 bg-red-50 text-red-600 font-bold border-l-4 border-red-600 rounded-r-xl" do %>
      <span class="material-symbols-outlined">grid_view</span>
      <span class="font-semibold">Todos</span>
    <% end %>
  </nav>
</aside>
