<% content_for :title, "Field Journal — Kanto Region" %>
<nav class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-lg flex items-center justify-between px-6 h-20 max-w-full mx-auto">
  <div class="flex items-center gap-4">
    <span class="text-2xl font-black uppercase tracking-tighter text-red-600">Field Journal</span>
  </div>
  <div class="hidden md:flex items-center gap-8">
    <%= link_to "Pokédex", pokemons_path, class: "text-red-600 font-bold" %>
  </div>
</nav>

<div class="flex min-h-screen pt-20 pb-24 md:pb-12">
  <aside class="hidden lg:flex flex-col py-8 px-6 gap-4 h-[calc(100vh-5rem)] w-80 fixed left-0 bg-surface">
    <div class="px-4 mb-4">
      <h2 class="font-headline text-sm font-semibold text-on-surface">Field Records</h2>
    </div>
    <nav class="space-y-1">
      <%= link_to pokemons_path, class: "flex items-center gap-4 px-4 py-3 bg-red-50 text-red-600 font-bold border-l-4 border-red-600 hover:translate-x-1 transition-transform duration-200" do %>
        <span class="material-symbols-outlined">grid_view</span>
        <span>Todos os Pokémon</span>
      <% end %>
    </nav>
    <div class="mt-auto p-4 bg-surface-container-low rounded-2xl">
      <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Registro regional</p>
      <div class="flex justify-between items-end">
        <span class="text-3xl font-black text-on-surface"><%= @total_species %></span>
        <span class="text-sm font-medium text-slate-500">espécies</span>
      </div>
      <div class="w-full bg-surface-variant h-1.5 rounded-full mt-3 overflow-hidden">
        <div class="bg-primary h-full w-3/4"></div>
      </div>
    </div>
  </aside>

  <main class="flex-1 lg:ml-80 px-6 md:px-12 py-8 max-w-7xl mx-auto w-full">
    <header class="mb-12 relative">
      <% first_num = @pokemons.first&.national_number.to_s.rjust(3, "0") || "001" %>
      <div class="absolute -top-12 -right-12 opacity-[0.03] pointer-events-none select-none hidden sm:block">
        <span class="text-[12rem] md:text-[20rem] font-black leading-none">#<%= first_num %></span>
      </div>
      <h1 class="font-headline text-4xl md:text-7xl font-bold tracking-tight text-on-surface mb-4">
        Explore a <span class="text-primary">região</span>
      </h1>
      <p class="text-lg text-on-surface-variant max-w-2xl mb-8 leading-relaxed">
        Classificação científica das espécies catalogadas. Lista ordenada pelo número nacional.
      </p>
    </header>

    <% if @pokemons.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @pokemons.each do |pokemon| %>
          <% primary = pokemon_types_ordered(pokemon).first %>
          <% styles = type_styles(primary&.name || "normal") %>
          <%= link_to pokemon_path(pokemon), class: "pokemon-card group relative bg-surface-container-lowest rounded-3xl p-6 transition-all duration-300 hover:shadow-[0_20px_40px_rgba(27,28,28,0.06)] overflow-hidden block" do %>
            <div class="absolute top-0 left-0 w-1 h-full <%= styles[:bar] %>"></div>
            <div class="flex justify-between items-start mb-4">
              <span class="text-sm font-bold text-slate-300 font-mono tracking-tighter">#<%= pokemon.national_number.to_s.rjust(3, "0") %></span>
              <div class="flex flex-wrap gap-1 justify-end max-w-[60%]">
                <% pokemon_types_ordered(pokemon).each do |t| %>
                  <% ts = type_styles(t.name) %>
                  <span class="px-2.5 py-1 <%= ts[:badge] %> rounded-lg text-xs font-bold uppercase tracking-wider"><%= t.name %></span>
                <% end %>
              </div>
            </div>
            <div class="aspect-square mb-6 flex items-center justify-center relative">
              <div class="absolute inset-0 <%= styles[:glow] %> rounded-full scale-75 opacity-50"></div>
              <% if pokemon.sprite_url.present? %>
                <%= image_tag pokemon.sprite_url, alt: pokemon.name, class: "pokemon-image relative z-10 w-40 h-40 object-contain transition-transform duration-500 ease-out" %>
              <% else %>
                <span class="material-symbols-outlined text-8xl text-slate-300 relative z-10">pets</span>
              <% end %>
            </div>
            <h3 class="text-2xl font-bold text-on-surface mb-1"><%= pokemon.name.titleize %></h3>
            <p class="text-sm text-slate-500 line-clamp-2"><%= pokemon.flavor_text.presence || "Sem descrição catalogada." %></p>
          <% end %>
        <% end %>
      </div>

      <div class="mt-16 flex flex-col items-center gap-6">
        <p class="text-slate-400 text-sm font-medium">
          Exibindo <%= @pokemons.size %> de <%= @total_species %> espécies documentadas
        </p>
      </div>
    <% else %>
      <div class="rounded-3xl bg-surface-container-low p-12 text-center max-w-lg mx-auto">
        <p class="text-on-surface text-lg">Nenhum Pokémon cadastrado ainda.</p>
        <p class="text-slate-500 mt-2 text-sm">Execute <code class="bg-surface-container-high px-2 py-0.5 rounded">bin/rails db:seed</code> para importar dados.</p>
      </div>
    <% end %>
  </main>
</div>
